DTEND;VALUE=DATE:20320912
END:VEVENT

BEGIN:VEVENT
UID:pow-mia-day-2032@honorary
SUMMARY:National POW/MIA Recognition Day
DESCRIPTION:Observed on the third Friday of September\, National POW/MIA Recognition Day honors American prisoners of war and those missing in action from all conflicts. The black POW/MIA flag is flown alongside the U.S. flag at federal buildings\, military installations\, and war memorials.
DTSTART;VALUE=DATE:20320917
DTEND;VALUE=DATE:20320918
END:VEVENT

BEGIN:VEVENT
